    <!-- HowTo Activity -->
    <string name="howto_title">User Guide</string>
    <string name="howto_scanner_title">📷 Barcode Scanner</string>
    <string name="howto_scanner_text">From the main screen, frame a food product barcode. The app will automatically search the product in the Open Food Facts database and identify all additives present in the ingredients.</string>
    <string name="howto_manual_title">🔍 Manual Search</string>
    <string name="howto_manual_text">Use the search bar to find specific additives. You can search by:\n\n• E-code (e.g: E100)\n• Common name (e.g: Curcumin)\n• Function (e.g: colorant)\n\nYou\'ll receive a list with all matching additives.</string>
    <string name="howto_classification_title">📊 Additive Classification</string>
    <string name="howto_classification_text">Each additive shows a colored bar indicating risk level. The more filled the bar, the greater the potential danger:</string>
    <string name="howto_classification_safe">Non-toxic - Safe for consumption</string>
    <string name="howto_classification_intolerance">Intolerance risk - Possible reactions in sensitive individuals</string>
    <string name="howto_classification_suspect">Suspicious - Safety studies ongoing</string>
    <string name="howto_classification_risky">Not recommended - Strong suspicion of toxicity</string>
    <string name="howto_classification_dangerous">Dangerous - May cause serious disorders</string>
    <string name="howto_classification_banned">Banned - Not allowed in the European Union</string>
    <string name="howto_nutriscore_title">🔤 Nutri-Score</string>
    <string name="howto_nutriscore_text">Nutri-Score is a nutritional labeling system developed in France and adopted in several European countries. It evaluates the overall nutritional quality of the product with a letter from A to E:</string>
    <string name="howto_nutriscore_a">Excellent nutritional quality</string>
    <string name="howto_nutriscore_b">Good nutritional quality</string>
    <string name="howto_nutriscore_c">Average nutritional quality</string>
    <string name="howto_nutriscore_d">Poor nutritional quality</string>
    <string name="howto_nutriscore_e">Very poor nutritional quality</string>
    <string name="howto_nutriscore_note">The calculation considers: calories, sugars, saturated fats, salt (negative) and fiber, proteins, fruits/vegetables (positive).</string>
    <string name="howto_nova_title">🏭 NOVA Score</string>
    <string name="howto_nova_text">The NOVA system classifies foods based on the degree of industrial processing, not nutritional quality:</string>
    <string name="howto_nova_1">Unprocessed or minimally processed foods (fruits, vegetables, fresh meat, milk)</string>
    <string name="howto_nova_2">Culinary ingredients (oil, butter, salt, sugar)</string>
    <string name="howto_nova_3">Processed foods (canned goods, cheeses, artisan bread)</string>
    <string name="howto_nova_4">Ultra-processed products (snacks, soft drinks, industrial ready meals)</string>
    <string name="howto_nova_note">Ultra-processed foods (NOVA 4) are associated with greater health risks if consumed in excess.</string>
    <string name="howto_ecoscore_title">🌍 Eco-Score</string>
    <string name="howto_ecoscore_text">The Eco-Score evaluates the environmental impact of food products considering the entire life cycle: production, transport, packaging, and end of life:</string>
    <string name="howto_ecoscore_a">Very low environmental impact - Eco-sustainable product</string>
    <string name="howto_ecoscore_b">Low environmental impact - Good ecological choice</string>
    <string name="howto_ecoscore_c">Moderate environmental impact - Average impact</string>
    <string name="howto_ecoscore_d">High environmental impact - Consider more sustainable alternatives</string>
    <string name="howto_ecoscore_e">Very high environmental impact - Strong environmental footprint</string>
    <string name="howto_ecoscore_note">The calculation considers: CO₂ emissions, water consumption, land use, packaging, transport, and biodiversity. Bonuses for organic certifications, fair trade, and recyclable packaging.</string>
    <string name="howto_profile_title">👤 Personal Profile</string>
    <string name="howto_profile_text">Configure your profile with:\n\n• Dietary preferences (vegan, vegetarian, halal)\n• Caution level on additives\n• Allergies and intolerances (14 EU allergens + nickel)\n• Custom intolerances (add specific ingredients to avoid)\n\nYou\'ll receive automatic alerts when a product contains additives or ingredients incompatible with your profile.</string>
    <string name="howto_features_title">⭐ Other Features</string>
    <string name="howto_features_text">• Favorites: Save products you scan most often\n• History: Check your previous scans\n• Sharing: Share results with friends and family\n• Offline: Manual search works even without internet</string>
    <string name="howto_data_title">📚 Data Sources</string>
    <string name="howto_data_text">• Local database: +400 additives with detailed descriptions\n• Open Food Facts: Collaborative food product database\n• EFSA: European Food Safety Authority\n\n⚠️ Note: Automatic detection depends on data quality on Open Food Facts. Some products may have missing or incomplete ingredients in the database. For certain results, always use manual search.\n\n📧 Reports: If you find products with missing or incorrect data, write to us at faustobe.azs@gmail.com</string>
    <string name="howto_tips_title">💡 Tips</string>
    <string name="howto_tips_text">• Configure your profile for personalized alerts\n• Use sharing to send results\n• Check full ingredients when available\n• Tap an additive to see all details\n• Use manual search to explore the database</string>

    <!-- About Activity -->
    <string name="about_title">About</string>
    <string name="about_subtitle">Food Additive Scanner</string>
    <string name="about_version">Version %s</string>
    <string name="about_info_title">ℹ️ Information</string>
    <string name="about_info_text">E-Codes is a free app that helps you identify and understand food additives in the products you consume daily.\n\nScan the barcode or search manually to get detailed information about safety, origin, and classification of additives.</string>
    <string name="about_developer_title">👨‍💻 Developer</string>
    <string name="about_developer_text">Developed by</string>
    <string name="about_sources_title">📚 Data Sources</string>
    <string name="about_sources_text">• Local food additive database\n• Open Food Facts API (products)\n• EFSA - European Food Safety Authority</string>
    <string name="about_libraries_title">🛠 Open Source Libraries</string>
    <string name="about_libraries_text">• CameraX (Google)\n• ML Kit Barcode Scanning (Google)\n• Material Design Components\n• OkHttp</string>
    <string name="about_privacy_title">🔒 Privacy</string>
    <string name="about_privacy_text">E-Codes respects your privacy:\n\n• No personal data collected\n• No account required\n• All data saved locally\n• No tracking or analytics\n• Internet connection only for Open Food Facts database</string>
    <string name="about_disclaimer_title">⚠️ Disclaimer</string>
    <string name="about_disclaimer_text">This app provides information about food additives for educational purposes. It does not replace advice from a doctor or nutritionist. For severe allergies or medical conditions, always consult a professional.</string>
